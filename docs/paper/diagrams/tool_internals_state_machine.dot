// Vignette 2: a state machine behind the elicitation tool.
//
// Workflow phases are nodes; transitions are guarded edges that depend on
// procedure state and user inputs. Each tool call reads the current node,
// chooses an outgoing edge whose guard is satisfied, advances to the next
// node, and returns the elicitation message attached to that node.

digraph tool_internals_state_machine {
  rankdir=LR;
  compound=true;
  graph [
    fontname="Helvetica",
    fontsize=11,
    nodesep=0.30,
    ranksep=0.45,
    pad="0.15",
  ];
  node [
    fontname="Helvetica",
    fontsize=11,
    shape=box,
    style="rounded,filled",
    color="#3F8A4A",
    fillcolor="#FFFFFF",
    margin="0.18,0.10",
  ];
  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#666666",
    arrowsize=0.7,
  ];

  agent  [label="LLM agent\n(single role)", fillcolor="#ECF6EE"];
  tool   [label="run_phase()"];

  subgraph cluster_sm {
    label = "State machine\n(phases + guarded transitions)";
    fontsize = 11;
    style    = "rounded,dashed";
    color    = "#3F8A4A";
    bgcolor  = "#F4FBE8";
    margin   = 14;

    n_disc   [label="privacy\ndisclosure"];
    n_cat    [label="issue\ncategory"];
    n_form   [label="form-filling\n(branch-aware)"];
    n_plan   [label="plan +\napproval"];
    n_done   [label="done"];

    n_disc -> n_cat   [label=" ack"];
    n_cat  -> n_form  [label=" category set"];
    n_form -> n_plan  [label=" all required\n fields stored"];
    n_plan -> n_done  [label=" plan_approval = yes"];
  }

  agent -> tool [label=" call"];
  tool  -> n_disc [lhead=cluster_sm, label=" read state"];
  n_disc -> tool  [ltail=cluster_sm, label=" elicitation\n for current node",
                   style=dashed];
  tool  -> agent  [label=" elicit / accepted /\n blocked payload",
                   style=dashed, color="#3F8A4A"];
}
