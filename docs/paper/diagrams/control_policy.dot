// Figure 1: Control-policy comparison.
//
// Shared substrate (task, validators, simulator, model) sits at the top.
// Two control policies sit below it: unguided (one large upfront prompt + a
// generic record_field tool, LLM steers from its own checklist) and guided
// (lean upfront prompt + a single collect_field tool that returns MCP-style
// elicitation payloads at the moment the procedure has the next step).
//
// The LLM is in the user-facing conversational loop in BOTH arms; the
// difference is the shape of the in-context guidance it receives.

digraph control_policy {
  rankdir=TB;
  graph [
    fontname="Helvetica",
    fontsize=11,
    nodesep=0.35,
    ranksep=0.55,
    splines=ortho,
    pad="0.2",
  ];
  node [
    fontname="Helvetica",
    fontsize=11,
    shape=box,
    style="rounded,filled",
    color="#999999",
    fillcolor="#FFFFFF",
    margin="0.18,0.10",
  ];
  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#666666",
    arrowsize=0.7,
  ];

  // ---- Shared substrate ----
  subgraph cluster_shared {
    label = "Shared across both arms";
    fontsize = 11;
    style    = "rounded,dashed";
    color    = "#999999";
    bgcolor  = "#F4F4F4";

    task   [label="Task & branching rules\n(disclosure → category → core fields →\nbranch fields → plan + approval → done)", fillcolor="#EAF1FB"];
    valid  [label="Validators\n(field formats, ordering,\nbranch obligations)", fillcolor="#EAF1FB"];
    sim    [label="Simulated user\n(persona + private GT)", fillcolor="#EAF1FB"];
    model  [label="Model\n(gpt-5.4-mini, both roles)", fillcolor="#EAF1FB"];

    {rank=same; task; valid; sim; model;}
  }

  // ---- Unguided arm ----
  subgraph cluster_unguided {
    label    = "Unguided control policy";
    labelloc = "t";
    fontsize = 12;
    style    = "rounded,filled";
    fillcolor= "#FFF2EC";
    color    = "#D17A4A";
    margin   = 14;

    u_prompt [label="Long upfront system prompt\n(checklist: ordering, branch,\ncompletion, all fields)", fillcolor="#FFFFFF", color="#D17A4A"];
    u_loop [label="LLM agent\nrelies on its own checklist;\nchooses on every turn:\nrecord_field / record_compliance /\nchat_only / done", fillcolor="#FFFFFF", color="#D17A4A"];
    u_state [label="Procedure state\n(validators only;\nno per-step guidance back)", fillcolor="#FFFFFF", color="#D17A4A"];
    u_done [label="done() iff LLM judges\nworkflow complete", fillcolor="#FFFFFF", color="#D17A4A"];

    u_prompt -> u_loop [label=" persistent system prompt"];
    u_loop -> u_state [label=" inline tool call\n (LLM-chosen timing)"];
    u_state -> u_loop [label=" pass/fail only", style=dashed, color="#666666"];
    u_loop -> u_done  [label=" judgment call",  style=dashed];
  }

  // ---- Guided arm ----
  subgraph cluster_guided {
    label    = "Guided control policy";
    labelloc = "t";
    fontsize = 12;
    style    = "rounded,filled";
    fillcolor= "#ECF6EE";
    color    = "#3F8A4A";
    margin   = 14;

    g_prompt [label="Lean upfront system prompt\n(tool surface + how to read\ncollect_field's return shape)", fillcolor="#FFFFFF", color="#3F8A4A"];
    g_proc  [label="Procedure\ntracks workflow position\n+ branch obligations", fillcolor="#FFFFFF", color="#3F8A4A"];
    g_chat  [label="LLM agent\ndrives the user-facing turn;\ncalls collect_field /\nrecord_compliance /\nchat_only / done", fillcolor="#FFFFFF", color="#3F8A4A"];
    g_check [label="collect_field tool\nreturns MCP-style elicitation\npayload (message + schema)\nor accepted / blocked record", fillcolor="#FFFFFF", color="#3F8A4A"];
    g_done  [label="done() gated by procedure\n(rejects early calls)", fillcolor="#FFFFFF", color="#3F8A4A"];

    g_prompt -> g_chat  [label=" persistent system prompt"];
    g_proc  -> g_chat   [label=" SYSTEM hint per turn:\n next required field"];
    g_chat  -> g_check  [label=" collect_field(name [, value])"];
    g_check -> g_proc   [label=" validate, store"];
    g_check -> g_chat   [label=" elicit / accepted / blocked\n payload (in-context)", style=dashed];
    g_chat  -> g_done   [label=" call done()"];
    g_proc  -> g_done   [label=" gate"];
  }

  // ---- Substrate to arms (compact) ----
  task  -> u_prompt [style=dotted, arrowhead=none, color="#999999"];
  task  -> g_proc   [style=dotted, arrowhead=none, color="#999999"];
  valid -> u_state  [style=dotted, arrowhead=none, color="#999999"];
  valid -> g_check  [style=dotted, arrowhead=none, color="#999999"];
  sim   -> u_loop   [style=dotted, arrowhead=none, color="#999999"];
  sim   -> g_chat   [style=dotted, arrowhead=none, color="#999999"];
}
