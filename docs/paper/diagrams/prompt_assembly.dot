// Guided vs unguided elicitation-style checkpoints (A/B).
digraph prompt_assembly {
  rankdir=TB;
  node [shape=box, style=rounded];
  edge [fontsize=10];

  Flow [label="Support intake flow\n(same requirements)"];
  Ung [label="Unguided arm\nLLM chooses when/how\nto capture fields"];
  Gd [label="Guided arm\nprocedure triggers\nform checkpoints"];
  Form [label="elicitation_form\n(authoritative capture\n+ validation)"];

  Flow -> Ung;
  Flow -> Gd;
  Form -> Gd [label="checkpoint for\nbranch-critical fields"];
}
