// Vignette 5: an orchestrator tool with continuation-passing.
//
// The orchestrator authors phase-level guidance. Its elicitation payloads can
// name a sub-tool the agent should call before returning. The agent acts as
// the scheduler; the conversation history is the call stack; the orchestrator's
// next_hint / resume_token field is the return address.

digraph tool_internals_orchestrator {
  rankdir=LR;
  graph [
    fontname="Helvetica",
    fontsize=11,
    nodesep=0.35,
    ranksep=0.55,
    pad="0.15",
  ];
  node [
    fontname="Helvetica",
    fontsize=11,
    shape=box,
    style="rounded,filled",
    color="#3F8A4A",
    fillcolor="#FFFFFF",
    margin="0.18,0.10",
  ];
  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#666666",
    arrowsize=0.7,
  ];

  agent  [label="LLM agent\n(single role,\nacts as scheduler)", fillcolor="#ECF6EE"];

  subgraph cluster_orch {
    label    = "Orchestrator tool";
    fontsize = 11;
    style    = "rounded,filled";
    color    = "#3F8A4A";
    fillcolor= "#F4FBE8";
    margin   = 14;

    orch    [label="run_phase()\n(phase author:\nstate machine OR soft script)"];
    pstate  [label="Procedure state\n(current phase,\ncompliance prerequisites)"];
    orch -> pstate [label=" read"];
    pstate -> orch [label=" eligible phases", style=dashed];
  }

  subgraph cluster_subs {
    label    = "Nested sub-tools";
    fontsize = 11;
    style    = "rounded,dashed";
    color    = "#3F8A4A";
    bgcolor  = "#FFFFFF";
    margin   = 12;

    sub_form [label="collect_field()\n(form-filling sub-tool;\ncompiled-in checklist)"];
    sub_disc [label="record_compliance()\n(privacy / fee disclosures)"];
    sub_done [label="done()\n(termination)"];
  }

  agent -> orch     [label=" call run_phase()"];
  orch  -> agent    [label=" elicit { message,\n next_hint: \"call sub-tool X\" }",
                     style=dashed, color="#3F8A4A"];

  agent -> sub_form [label=" call (per next_hint)"];
  agent -> sub_disc [label=" call (per next_hint)"];
  agent -> sub_done [label=" call (per next_hint)"];

  sub_form -> agent [label=" accepted /\n elicit", style=dashed, color="#3F8A4A"];
  sub_disc -> agent [label=" accepted", style=dashed, color="#3F8A4A"];

  agent -> orch     [label=" re-call with\n sub-tool result",
                     style=dotted, color="#3F8A4A"];
}
