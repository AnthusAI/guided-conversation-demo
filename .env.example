# Required for the LLM-backed simulator and agent runs.
# Copy this file to `.env`, then paste your real key after the equals sign.
OPENAI_API_KEY=

# Conservative defaults for smoke testing the experiment harness.
# Increase these only when you are ready to spend more API time/cost.
RELIABILITY_RUNS=1
RELIABILITY_CONCURRENCY=1
RELIABILITY_PAIR_USER_SIM=1
RELIABILITY_RETRY_INFRA=1
SUPPORT_RELIABILITY_RUN_TAG=smoke

# Optional knobs. Leave commented unless you need to override the defaults.
# RELIABILITY_USER_TEMP=0.7
# SUPPORT_RELIABILITY_MAX_TURNS=58
# SUPPORT_RELIABILITY_PATIENCE_BUDGET=4
